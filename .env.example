# ============================================================
# CPS Security Project — Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# ============================================================

# --- Kaggle Credentials ---
# Required for downloading the SWaT dataset.
# Generate these from Kaggle -> Settings -> Create New API Token (downloads kaggle.json)
KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_api_key_here

# --- MongoDB Credentials ---
# Required for logging training experiments and evaluation metrics.
# Paste your MongoDB Atlas cloud URI or local database URI.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.your_host.mongodb.net
MONGODB_DB_NAME=cps_security
