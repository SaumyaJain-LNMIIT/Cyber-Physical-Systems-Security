experiments/results/my_first_run_config.yaml
experiments/results/my_first_run_model.pt
experiments/results/my_first_run_scaler.pkl
experiments/results/smoke_test_model.pt
experiments/results/dashboard_run_model.pt

# Do NOT ignore pre-trained models / verification config required for local verification 
